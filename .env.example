# ─── Configuration des imports & de l'IA ───────────────────────────────────
# Copie ce fichier en .env.local (ignoré par git) et renseigne tes clés.
# Redémarre le serveur (npm run dev) après modification.

# Clé API Anthropic — débloque :
#   • l'import « Depuis une URL » (analyse du screenshot par Claude Vision)
#   • l'assistant Claude par bloc (panneau de droite)
# Obtenir une clé : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# (Optionnel) Token Browserless — extraction DOM haute fidélité pour l'import URL.
# Si présent, il est utilisé en priorité (positions + styles réels, plus précis
# que la capture + Vision). Sinon on retombe sur Microlink + Claude Vision.
# https://www.browserless.io/
BROWSERLESS_TOKEN=

# Rappels :
#   • L'import URL ne fonctionne que sur des URL PUBLIQUES (pas localhost).
#   • Pour une app locale / un projet git non déployé, utilise plutôt
#     « Importer → Depuis ton app (scan) » : aucun clé ni cloud requis.
